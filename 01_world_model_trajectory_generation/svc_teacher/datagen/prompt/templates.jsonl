// A1. Distance Regression (Translation Only: forward/backward/left/right)
{
    "task_type": "A1",
    "messages": [
      {
        "role": "user",
        "content": "<image><image>How many meters did the camera move to get the second image? Answer as: move {DIR} X meters."
      },
      {
        "role": "assistant",
        "content": "move {DIR} {DIST} meters"
      }
    ],
    "images": ["{IMG_1}", "{IMG_2}"]
}

// A2. Angle Regression (Rotation Only: turn left/right)
{
    "task_type": "A2",
    "messages": [
      {
        "role": "user",
        "content": "<image><image>How many degrees did the camera turn to get the second image? Answer as: turn {TURN_DIR} X degrees."
      },
      {
        "role": "assistant",
        "content": "turn {TURN_DIR} {ANGLE} degrees"
      }
    ],
    "images": ["{IMG_1}", "{IMG_2}"]
}


// A3. Action Sequence (Two/Three-Step Only: write actions in order)
{
    "task_type": "A3",
    "messages": [
      {
        "role": "user",
        "content": "<image><image>To move from the first image to the second image, the camera used 2 or 3 actions in order. Write the full action sequence using ';' as a separator. Allowed actions:\n- move forward/backward/left/right X meters\n- turn left/right X degrees"
      },
      {
        "role": "assistant",
        "content": "{ACTION_SEQ}"
      }
    ],
    "images": ["{IMG_1}", "{IMG_2}"]
}

// A4. Yes/No Verification (Given action statement: true or false)
{
    "task_type": "A4",
    "messages": [
      {
        "role": "user",
        "content": "<image><image>True or false: the camera did \"{CLAIM_ACTION}\" to get the second image."
      },
      {
        "role": "assistant",
        "content": "{TF}"
      }
    ],
    "images": ["{IMG_1}", "{IMG_2}"]
}

